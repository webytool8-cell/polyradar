# ── Polymarket CLOB credentials ─────────────────────────────────────────────
# Get these from https://polymarket.com → Profile → API Keys
POLY_API_KEY=
POLY_API_SECRET=
POLY_PASSPHRASE=
POLY_HOST=https://clob.polymarket.com

# ── Market condition IDs ──────────────────────────────────────────────────────
# Find these by running:  python bot.py --discover-markets
BTC_5M_CONDITION_ID=
BTC_15M_CONDITION_ID=
ETH_5M_CONDITION_ID=
ETH_15M_CONDITION_ID=

# ── Signal thresholds ────────────────────────────────────────────────────────
LAG_THRESHOLD=0.03        # flag when Poly odds lag CEX by this many probability points
MIN_EDGE=0.05             # minimum edge (as fraction) required to place a trade
MAX_POSITION_PCT=0.08     # maximum single position as fraction of portfolio
MIN_CONFIDENCE=0.85       # minimum CEX-model confidence required
KELLY_FRACTION=0.5        # half-Kelly (0.5) or full-Kelly (1.0)

# ── Risk management ───────────────────────────────────────────────────────────
MAX_DAILY_DRAWDOWN=0.20   # kill switch triggers at 20% daily drawdown

# ── Paper trading ────────────────────────────────────────────────────────────
INITIAL_BALANCE=10000.0   # starting paper balance in USDC

# ── Volatility assumptions (annualised, used in GBM probability model) ───────
BTC_ANNUAL_VOL=0.80
ETH_ANNUAL_VOL=0.90

# ── Polymarket polling ───────────────────────────────────────────────────────
POLY_POLL_INTERVAL=2.0    # seconds between orderbook polls

# ── Telegram alerts ───────────────────────────────────────────────────────────
# Create a bot via @BotFather, then get your chat ID via @userinfobot
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
